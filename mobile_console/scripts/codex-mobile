#!/usr/bin/env bash
set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: codex-mobile <repo_dir> [codex args...]" >&2
  exit 1
fi

repo_dir="$1"
shift || true

cd "$repo_dir"
export TERM="xterm-256color"
export PYTHONUNBUFFERED=1

# Mobile default: full filesystem/network access and no per-command approval prompts.
# Note: sudo-password prompts are still handled by the OS/sudo itself.
exec codex \
  --sandbox danger-full-access \
  --ask-for-approval never \
  "$@"

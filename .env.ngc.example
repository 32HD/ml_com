# Copy this file to .env.ngc before first run.
# UID/GID should match your host user to avoid root-owned files.
UID=1000
GID=1000

# Timezone inside container.
TZ=UTC

# NGC image.
NGC_IMAGE=nvcr.io/nvidia/pytorch:25.02-py3
# If you build the local communication image, use:
# NGC_IMAGE=local/ngc-comms:25.02

# GPU selection.
NGC_GPUS=all
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility
